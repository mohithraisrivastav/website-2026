# Copy to .env.local and fill in real values.
# Never commit .env.local to git.

# Razorpay (get from dashboard.razorpay.com -> Settings -> API Keys)
# RAZORPAY_KEY_ID is the public browser key returned by /api/config.
# RAZORPAY_KEY_SECRET must remain server-side only.
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Resend (get from resend.com -> API Keys)
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXX
